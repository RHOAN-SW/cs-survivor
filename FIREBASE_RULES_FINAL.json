{
  "rules": {
    "leaderboard": {
      // 누구나 랭킹을 읽을 수 있습니다.
      ".read": true,
      
      "$score_id": {
        // 1. 데이터가 없을 때(새로운 등록)는 누구나 쓰기 허용
        // 2. 혹은 요청에 admin_secret이 포함되어 있으면 삭제/수정 허용
        ".write": "!data.exists() || (auth != null && auth.token.admin === true) || (query.auth == 'YOUR_DATABASE_SECRET_OR_SIMILAR')",
        
        // 데이터 형식 검증 (필수 필드 확인)
        ".validate": "newData.hasChildren(['nickname', 'time', 'level'])"
      }
    }
  }
}
